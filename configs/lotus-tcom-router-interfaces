
auto eth0
iface eth0 inet static
	address 203.0.113.3
	netmask 255.255.255.254
	gateway 203.0.113.2
	post-up echo 1 > /proc/sys/net/ipv4/ip_forward


auto eth1
iface eth1 inet static
	address 203.0.113.129
	netmask 255.255.255.248
	pre-up rm -f /var/lib/dhcp/dhcpd.leases
	pre-up touch /var/lib/dhcp/dhcpd.leases
	post-up killall dhcpd; dhcpd -4 -f -cf /etc/dhcp/dhcpd.conf eth1 &





